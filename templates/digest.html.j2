<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>【法令アップデート】{{ week_range }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            apple: {
              black:  '#1d1d1f',
              gray:   '#f5f5f7',
              mid:    '#d2d2d7',
              sub:    '#6e6e73',
              white:  '#ffffff',
            }
          },
          fontFamily: {
            sans: ['Inter', '-apple-system', 'BlinkMacSystemFont', 'Helvetica Neue', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    html { scroll-behavior: smooth; background-color: #f5f5f7; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif; }
    .bar-high { border-left: 3px solid #1B48C4; }
    .bar-mid  { border-left: 3px solid #6e6e73; }
    .bar-low  { border-left: 3px solid #d2d2d7; }
    .badge-high { background: #1B48C4; color: #fff; }
    .badge-mid  { background: #6e6e73; color: #fff; }
    .badge-low  { background: #d2d2d7; color: #6e6e73; }
    .summary-row-high:hover { background: #EEF2FC; }
    .summary-row-high { transition: background 0.15s ease; }
    .summary-row:hover { background: #f0f0f2; }
    .summary-row { transition: background 0.15s ease; }
    a { text-decoration: none; }
    @media print {
      html { background-color: #fff; }
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .max-w-2xl { max-width: 100% !important; margin: 0 !important; }
      .rounded-t-2xl, .rounded-b-2xl { border-radius: 0 !important; }
      .my-10 { margin-top: 0 !important; margin-bottom: 0 !important; }
      #scrollTopBtn { display: none !important; }
      a[href="#detail-report"] { display: none !important; }
      [id^="detail-"] { break-inside: avoid; page-break-inside: avoid; }
      .border-t.border-apple-mid { break-after: auto; }
      .summary-row-high:hover, .summary-row:hover { background: transparent !important; }
      a[href]::after { content: none !important; }
      body { font-size: 10pt; }
    }
  </style>
</head>
<body class="text-apple-black">

  <div class="max-w-2xl mx-auto my-10">

    <!-- ヘッダー -->
    <div class="bg-apple-white px-10 pt-10 pb-8 rounded-t-2xl border-b border-apple-mid">
      <p class="text-xs text-apple-sub mb-1 font-light tracking-wide">
        Legal Update System &nbsp;→&nbsp; {{ recipient_email }}
      </p>
      <p class="text-xs text-apple-sub mb-6 font-light">
        {{ send_datetime }}
      </p>

      <h1 style="font-family:'Playfair Display',Georgia,serif; font-size:2.4rem; font-weight:700; letter-spacing:-0.01em; line-height:1.1; color:#1d1d1f;">
        The Brief
      </h1>
      <p class="text-sm text-apple-sub mt-2 font-light tracking-wide">{{ week_range }}</p>

      <!-- 件数サマリー -->
      <div class="flex gap-5 mt-6">
        <div class="text-center">
          <div class="text-2xl font-semibold" style="color:#1B48C4">{{ count_high }}</div>
          <div class="text-xs font-medium mt-0.5" style="color:#1B48C4">重要</div>
        </div>
        <div class="w-px bg-apple-mid"></div>
        <div class="text-center">
          <div class="text-2xl font-semibold text-apple-black">{{ count_mid }}</div>
          <div class="text-xs text-apple-sub mt-0.5 font-light">中</div>
        </div>
        <div class="w-px bg-apple-mid"></div>
        <div class="text-center">
          <div class="text-2xl font-semibold text-apple-black">{{ count_low }}</div>
          <div class="text-xs text-apple-sub mt-0.5 font-light">参考</div>
        </div>
      </div>
    </div>

    <!-- メイン -->
    <div class="bg-apple-white px-10 py-10 space-y-12 rounded-b-2xl">

      {# ━━━ サマリー ━━━ #}
      <section id="summary">
        <h2 class="text-xs font-semibold text-apple-sub uppercase tracking-widest mb-5">
          今週のサマリー
        </h2>

        {% for category in categories %}
        <div class="mb-8">
          <h3 class="text-sm font-bold text-apple-black mb-3 pb-2 border-b border-apple-mid">
            {{ category.name }}
          </h3>
          <div class="space-y-1">
            {% for item in category["items"] %}
              {% if item.importance == 'high' %}
                {% set row_cls = 'summary-row-high' %}
                {% set bar_cls = 'bar-high' %}
                {% set badge_cls = 'badge-high' %}
                {% set badge_label = '重要' %}
              {% elif item.importance == 'mid' %}
                {% set row_cls = 'summary-row' %}
                {% set bar_cls = 'bar-mid' %}
                {% set badge_cls = 'badge-mid' %}
                {% set badge_label = '中' %}
              {% else %}
                {% set row_cls = 'summary-row' %}
                {% set bar_cls = 'bar-low' %}
                {% set badge_cls = 'badge-low' %}
                {% set badge_label = '参考' %}
              {% endif %}

              {% if item.importance == 'low' %}
                {# low は詳細セクションが無いので元 URL に直接リンク #}
                <a href="{{ item.url }}" target="_blank" rel="noopener" class="{{ row_cls }} flex items-center gap-4 px-3 py-3 rounded-lg {{ bar_cls }} pl-5">
              {% else %}
                <a href="#detail-{{ item.id }}" class="{{ row_cls }} flex items-center gap-4 px-3 py-3 rounded-lg {{ bar_cls }} pl-5">
              {% endif %}
                <span class="{{ badge_cls }} text-xs font-medium px-2 py-0.5 rounded shrink-0">{{ badge_label }}</span>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-medium truncate">{{ item.headline }}</div>
                  <div class="text-xs text-apple-sub mt-0.5 font-light">
                    {%- if item.affected_clients -%}
                      {{ item.affected_clients[0] }}
                    {%- endif -%}
                    {%- if item.key_date.date_str -%}
                      　／　{{ item.key_date.label }}：{{ item.key_date.date_str }}
                    {%- endif -%}
                  </div>
                </div>
                <span class="text-apple-sub text-xs shrink-0">
                  {%- if item.importance == 'low' -%}↗{%- else -%}↓{%- endif -%}
                </span>
              </a>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </section>

      {% if detail_items %}
      <div class="text-center pt-2">
        <a href="#detail-report" class="inline-flex items-center gap-1.5 text-xs font-medium px-5 py-2 rounded-full border border-apple-mid text-apple-sub hover:border-apple-black hover:text-apple-black transition">
          詳細レポートを読む <span class="text-base leading-none">↓</span>
        </a>
      </div>

      <div class="border-t border-apple-mid"></div>

      {# ━━━ 詳細レポート ━━━ #}
      <section id="detail-report">
        <h2 class="text-xs font-semibold text-apple-sub uppercase tracking-widest mb-8">
          詳細レポート
        </h2>

        <div class="space-y-10">
          {% for item in detail_items %}
            {% if item.importance == 'high' %}
              {% set badge_cls = 'badge-high' %}
              {% set badge_label = '重要（AI仮判定）' %}
            {% else %}
              {% set badge_cls = 'badge-mid' %}
              {% set badge_label = '中（AI仮判定）' %}
            {% endif %}

            <div id="detail-{{ item.id }}" class="scroll-mt-6">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <div class="flex items-center gap-3 mb-2">
                    <span class="{{ badge_cls }} text-xs font-medium px-2 py-0.5 rounded">{{ badge_label }}</span>
                    <span class="text-xs text-apple-sub font-light">{{ item.category }}　／　{{ item.regulator }}</span>
                  </div>
                  <h3 class="text-base font-semibold leading-snug">
                    {{ item.headline }}
                  </h3>
                  <p class="text-xs text-apple-sub font-light mt-2 italic">
                    AI仮判定の理由: {{ item.judgment_reason }}
                  </p>
                </div>
                <a href="#summary" class="text-xs text-apple-sub hover:text-apple-black shrink-0 ml-6 mt-1">↑ サマリーへ</a>
              </div>

              <!-- メタ情報 -->
              <div class="grid grid-cols-3 gap-3 mb-5">
                <div class="bg-apple-gray rounded-xl px-4 py-3">
                  <div class="text-xs text-apple-sub mb-1 font-light">種別</div>
                  <div class="text-xs font-medium">{{ item.axis_breakdown.legal_form.value }}</div>
                </div>
                <div class="bg-apple-gray rounded-xl px-4 py-3">
                  <div class="text-xs text-apple-sub mb-1 font-light">所管</div>
                  <div class="text-xs font-medium">{{ item.regulator }}</div>
                </div>
                <div class="bg-apple-gray rounded-xl px-4 py-3">
                  <div class="text-xs text-apple-sub mb-1 font-light">{{ item.key_date.label or '公表' }}</div>
                  <div class="text-xs font-medium">{{ item.key_date.date_str or '—' }}</div>
                </div>
              </div>

              <div class="space-y-4 text-sm font-light leading-relaxed text-apple-black">
                <div>
                  <div class="text-xs font-semibold text-apple-sub mb-1.5">変更点</div>
                  <p>{{ item.change_summary }}</p>
                </div>
                {% if item.affected_clients %}
                <div>
                  <div class="text-xs font-semibold text-apple-sub mb-1.5">注意が必要なクライアント</div>
                  <div class="flex flex-wrap gap-2">
                    {% for client in item.affected_clients %}
                      <span class="border border-apple-mid text-xs px-3 py-1 rounded-full">{{ client }}</span>
                    {% endfor %}
                  </div>
                </div>
                {% endif %}
                <div>
                  <div class="text-xs font-semibold text-apple-sub mb-1.5">実務上の対応</div>
                  <p>{{ item.practical_action }}</p>
                </div>
              </div>

              <div class="flex gap-3 mt-5">
                <a href="{{ item.url }}" target="_blank" rel="noopener" class="text-xs font-medium px-4 py-2 rounded-full text-white transition" style="background:#1B48C4;">
                  {{ item.regulator }} 原文 →
                </a>
              </div>
            </div>

            {% if not loop.last %}
            <div class="border-t border-apple-mid"></div>
            {% endif %}
          {% endfor %}
        </div>
      </section>
      {% endif %}

      <!-- フッター -->
      <div class="border-t border-apple-mid pt-6 space-y-1">
        <p class="text-xs text-apple-sub font-light border border-apple-mid rounded-lg px-4 py-3 leading-relaxed mb-3">
          重要度はAIによる仮判定です。最終的な判断は一次情報源にてご確認ください。
        </p>
        <p class="text-xs text-apple-sub font-light">このメールはLegal Update Systemにより自動生成されました。</p>
        <p class="text-xs text-apple-sub font-light">次回配信：{{ next_send_date }}</p>
      </div>

    </div>
  </div>

  <button id="scrollTopBtn"
    onclick="window.scrollTo({top:0,behavior:'smooth'})"
    class="fixed bottom-6 right-6 w-10 h-10 rounded-full shadow-lg flex items-center justify-center transition-all duration-300 opacity-0 pointer-events-none"
    style="background:#1d1d1f; color:#fff; font-size:1rem;"
    aria-label="ページトップへ">
    ↑
  </button>
  <script>
    const btn = document.getElementById('scrollTopBtn');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
      } else {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
      }
    });
  </script>

</body>
</html>
